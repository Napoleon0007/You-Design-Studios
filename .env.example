# Copy to .env (git-ignored) and fill in. Never commit real keys.
GELATO_API_KEY=
# Second fulfilment provider (apparel) — used when products are tagged provider=printful:
PRINTFUL_API_KEY=
# Third provider (Gooten) — RecipeID is public (in URL), PartnerBillingKey is PRIVATE (orders only):
GOOTEN_RECIPE_ID=
GOOTEN_PARTNER_BILLING_KEY=
# Set in production so the print provider gets absolute print-file URLs
# AND so Paystack callback + magic-link emails use the real origin:
PUBLIC_BASE_URL=

# --- Payments (Paystack, South Africa) -------------------------------------
# TEST keys are free (no bank/KYC): get them at dashboard.paystack.com → Settings → API.
# With NO key set, checkout runs in dev mode (a "simulate payment" link) so the
# whole escrow/email/admin flow is testable. sk_test→sk_live to go live, no code change.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# --- Transactional email (Resend) ------------------------------------------
# With NO key set, emails render to data/outbox/*.html (open via /outbox/<file>)
# instead of sending. Add a key at resend.com to send for real.
RESEND_API_KEY=
# Verified sender once you add your domain in Resend (defaults to a Resend test sender):
MAIL_FROM=You Design Studios <onboarding@resend.dev>

# --- Shipping model (Luke's call — flip the strategy, no code change) -------
# flat_free_over (default) | flat | passthrough (real courier cost) | free
SHIPPING_STRATEGY=flat_free_over
SHIPPING_FLAT_CENTS=8000          # R80 flat fee
SHIPPING_FREE_OVER_CENTS=80000    # free shipping over R800

# --- Admin -----------------------------------------------------------------
# Guards /admin/moderation + /admin/orders. MUST be set before deploying
# (open on localhost only when unset). Append ?key=... or send X-Admin-Key.
ADMIN_KEY=
# Optional: shared secret for the Gooten webhook (?token=...)
GOOTEN_WEBHOOK_SECRET=
